NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

DATABASE_URL=postgresql://linkchat:linkchat_dev@localhost:5432/linkchat?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

REDIS_URL=redis://localhost:6379

# Email (OTP) - use Ethereal for dev or SMTP
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Link-Chat <noreply@linkchat.app>

# S3 / MinIO compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=linkchat-media
S3_ACCESS_KEY=linkchat
S3_SECRET_KEY=linkchat_dev_secret
S3_PUBLIC_URL=http://localhost:9000/linkchat-media

CORS_ORIGIN=http://localhost:3000
